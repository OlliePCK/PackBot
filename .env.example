# PackBot environment — full reference with defaults and caveats: ENVIRONMENT.md

# Discord (required)
TOKEN=
CLIENT_ID=

# Slash-command registration (bulk overwrite on startup — see ENVIRONMENT.md
# warnings; leave false in production except when the command set changes)
REGISTER_COMMANDS=false
DEV_GUILD_ID=

# MySQL/MariaDB (required)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# Music — Lavalink v4 node (empty address disables music)
LAVALINK_ADDRESS=localhost:2333
LAVALINK_PASSWORD=

# Spotify link resolution (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API — /youtube command + upload notifications (optional)
YOUTUBE_API_KEY=
PROXY_URL=
YT_MAX_BACKOFF_MULTIPLIER=8

# Web API
ENABLE_API=true
API_PORT=3001
CORS_ORIGIN=https://your-domain.com
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
FRONTEND_URL=https://your-domain.com
API_ADMIN_USER_ID=
NODE_ENV=production

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
