TOKEN=<"bot_token">
CLIENT_ID=<"client_id">
MYSQL_HOST=<"db_address">
MYSQL_PORT=<"db_port">
MYSQL_USER=<"db_user">
MYSQL_PASSWORD=<"db_passwd">
MYSQL_DB=<"db_name">

# Web API Configuration
NODE_ENV=production
API_PORT=3001
ENABLE_API=true
CORS_ORIGIN=https://your-domain.com
SESSION_SECRET=<"random_secret_string">
DISCORD_CLIENT_SECRET=<"discord_oauth_client_secret">
OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
FRONTEND_URL=https://your-domain.com

# API Keys (optional)
YOUTUBE_API_KEY=<"yt_api_v3_key">
SPOTIFY_CLIENT_ID=<"spotify_client_id">
SPOTIFY_CLIENT_SECRET=<"spotify_client_secret">
DEEPGRAM_API_KEY=<"deepgram_api_key">
OPENAI_API_KEY=<"openai_api_key">
PROXY_URL=

# Logging (optional)
LOG_LEVEL=info
LOG_FORMAT=text
LOG_COLORS=false
LOG_DIR=logs
LOG_MAX_SIZE_MB=5
LOG_MAX_FILES=5
LOG_MUSIC_TIMINGS=false
LOG_YTDLP_TIMINGS=false

# Music playback tuning (optional, canonical keys)
MUSIC_STREAM_MODE=auto
MUSIC_OPUS_PASSTHROUGH=true
YTDLP_RESOLVE_DIRECT_URL=false
YT_SEARCH_PROVIDER=auto
YTDLP_DIRECT_FAST=true
YTDLP_DIRECT_TIMEOUT_MS=15000
YTDLP_INFO_TIMEOUT_MS=30000
YTDLP_FORCE_IPV4=false
YTDLP_EXTRACTOR_ARGS=
YTDLP_PREFETCH_BYTES=
YTDLP_JS_RUNTIME=node
YTDLP_REMOTE_COMPONENTS=ejs:github
YTDLP_CONFIG_PATH=/root/.config/yt-dlp/config
YTDLP_COOKIES_PATH=/usr/src/app/cookies.txt
YTDLP_PATH=/usr/local/bin/yt-dlp
YT_MAX_BACKOFF_MULTIPLIER=8

# Runtime
TZ=Australia/Sydney
