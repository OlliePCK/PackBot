<?xml version="1.0"?>
<Container version="2">
  <Name>PackBot-Go</Name>
  <Repository>olliepck/packbot-go:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>host</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/OlliePCK/PackBot/issues</Support>
  <Project>https://github.com/OlliePCK/PackBot</Project>
  <Overview>PackBot (Go rewrite): Discord bot with Lavalink music, web API + realtime WebSocket, MySQL persistence. Static binary on distroless — no volumes needed; logs to stdout. Requires the PackBot-Lavalink container for music.</Overview>
  <Category>Network:Other Tools:Utilities</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/OlliePCK/PackBot/master/unraid/my-PackBot-Go.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/OlliePCK/PackBot/master/unraid/packbot-icon.jpg</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>PackBot-Lavalink (for music)</Requires>

  <Config Name="TOKEN" Target="TOKEN" Default="" Mode="" Description="Discord bot token" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="CLIENT_ID" Target="CLIENT_ID" Default="" Mode="" Description="Discord application client ID" Type="Variable" Display="always" Required="true" Mask="false"></Config>
  <Config Name="MYSQL_HOST" Target="MYSQL_HOST" Default="mariadb" Mode="" Description="MySQL host (container name or IP)" Type="Variable" Display="always" Required="true" Mask="false">mariadb</Config>
  <Config Name="MYSQL_PORT" Target="MYSQL_PORT" Default="3306" Mode="" Description="MySQL port" Type="Variable" Display="always" Required="true" Mask="false">3306</Config>
  <Config Name="MYSQL_USER" Target="MYSQL_USER" Default="packbot" Mode="" Description="MySQL username" Type="Variable" Display="always" Required="true" Mask="false">packbot</Config>
  <Config Name="MYSQL_PASSWORD" Target="MYSQL_PASSWORD" Default="" Mode="" Description="MySQL password" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="MYSQL_DB" Target="MYSQL_DB" Default="packbot" Mode="" Description="MySQL database name" Type="Variable" Display="always" Required="true" Mask="false">packbot</Config>

  <Config Name="LAVALINK_ADDRESS" Target="LAVALINK_ADDRESS" Default="localhost:2333" Mode="" Description="Lavalink node address (empty disables music)" Type="Variable" Display="always" Required="false" Mask="false">localhost:2333</Config>
  <Config Name="LAVALINK_PASSWORD" Target="LAVALINK_PASSWORD" Default="" Mode="" Description="Lavalink node password" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="AFL_API_URL" Target="AFL_API_URL" Default="" Mode="" Description="AFL prediction dashboard base URL (empty disables /tips and AFL announcements)" Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="SPOTIFY_CLIENT_ID" Target="SPOTIFY_CLIENT_ID" Default="" Mode="" Description="Spotify client ID (link resolution + search enrichment)" Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="SPOTIFY_CLIENT_SECRET" Target="SPOTIFY_CLIENT_SECRET" Default="" Mode="" Description="Spotify client secret" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="YOUTUBE_API_KEY" Target="YOUTUBE_API_KEY" Default="" Mode="" Description="YouTube Data API key (scored matching, /youtube, upload notifications)" Type="Variable" Display="always" Required="false" Mask="true"></Config>

  <Config Name="REGISTER_COMMANDS" Target="REGISTER_COMMANDS" Default="false" Mode="" Description="Bulk-overwrite slash commands on startup (see ENVIRONMENT.md warnings)" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="DEV_GUILD_ID" Target="DEV_GUILD_ID" Default="" Mode="" Description="Guild-scope command registration (testing only; empty = global)" Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="ENABLE_API" Target="ENABLE_API" Default="true" Mode="" Description="Enable PackBot web API" Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="API_PORT" Target="API_PORT" Default="3001" Mode="" Description="API port (host network)" Type="Variable" Display="advanced" Required="false" Mask="false">3001</Config>
  <Config Name="NODE_ENV" Target="NODE_ENV" Default="production" Mode="" Description="production enables Secure session cookies" Type="Variable" Display="advanced" Required="false" Mask="false">production</Config>
  <Config Name="CORS_ORIGIN" Target="CORS_ORIGIN" Default="https://thepck.com" Mode="" Description="CORS origin for API requests" Type="Variable" Display="advanced" Required="false" Mask="false">https://thepck.com</Config>
  <Config Name="DISCORD_CLIENT_SECRET" Target="DISCORD_CLIENT_SECRET" Default="" Mode="" Description="Discord OAuth client secret for web login" Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="OAUTH_REDIRECT_URI" Target="OAUTH_REDIRECT_URI" Default="https://thepck.com/api/auth/callback" Mode="" Description="Discord OAuth redirect URI" Type="Variable" Display="advanced" Required="false" Mask="false">https://thepck.com/api/auth/callback</Config>
  <Config Name="FRONTEND_URL" Target="FRONTEND_URL" Default="https://thepck.com" Mode="" Description="Frontend URL for OAuth redirects" Type="Variable" Display="advanced" Required="false" Mask="false">https://thepck.com</Config>
  <Config Name="API_ADMIN_USER_ID" Target="API_ADMIN_USER_ID" Default="" Mode="" Description="Discord user ID with web super-admin access" Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="PROXY_URL" Target="PROXY_URL" Default="" Mode="" Description="Optional HTTP proxy for YouTube upload polling" Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="YT_MAX_BACKOFF_MULTIPLIER" Target="YT_MAX_BACKOFF_MULTIPLIER" Default="8" Mode="" Description="YouTube polling backoff cap" Type="Variable" Display="advanced" Required="false" Mask="false">8</Config>
  <Config Name="LOG_LEVEL" Target="LOG_LEVEL" Default="info" Mode="" Description="Log level: debug|info|warn|error (stdout only)" Type="Variable" Display="advanced" Required="false" Mask="false">info</Config>
  <Config Name="LOG_FORMAT" Target="LOG_FORMAT" Default="text" Mode="" Description="Log format: text|json" Type="Variable" Display="advanced" Required="false" Mask="false">text</Config>
  <Config Name="TZ" Target="TZ" Default="Australia/Sydney" Mode="" Description="Container timezone" Type="Variable" Display="advanced" Required="false" Mask="false">Australia/Sydney</Config>

  <TailscaleStateDir/>
</Container>
